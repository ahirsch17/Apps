# ===================================
node_modules/
.npm/
.yarn/
.pnp.*
.yarn-integrity

# ===================================
# REACT NATIVE
# ===================================
*.log

# ===================================
# BUILD OUTPUTS
# ===================================
# iOS - Keep project files, exclude builds
ios/Pods/
ios/build/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
*.ipa
*.dSYM.zip
*.dSYM

# ===================================
# METRO / BUNDLER
# ===================================
.metro/
.metro-health-check*
.haste_cache/
.haste-map*
.history/
metro.config.js.bak
metro-cache/

# ===================================
# DEBUG & LOGS
# ===================================
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
logs/

# ===================================
# ENVIRONMENT
# ===================================
.env
.env.local
.env.production
.env.development
.env.test
.env*.local

# ===================================
# IDE & EDITOR
# ===================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
*.launch
.settings/

