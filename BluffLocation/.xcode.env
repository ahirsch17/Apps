#!/bin/bash
# This `.xcode.env` file is versioned and is used to source the user's `.xcode.env.local` file
# This allows users to specify a custom node path or environment variables
# without affecting the team's repository.

# NODE_BINARY variable contains the PATH to the node executable.
export NODE_BINARY=$(command -v node)

# If node is not found in PATH, try common locations
if [ -z "$NODE_BINARY" ]; then
  if [ -f "/opt/homebrew/bin/node" ]; then
    export NODE_BINARY="/opt/homebrew/bin/node"
  elif [ -f "/usr/local/bin/node" ]; then
    export NODE_BINARY="/usr/local/bin/node"
  elif [ -f "$HOME/.nvm/versions/node/$(nvm version)/bin/node" ]; then
    export NODE_BINARY="$HOME/.nvm/versions/node/$(nvm version)/bin/node"
  fi
fi

